---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const prequels = (await getCollection('prequel')).sort((a, b) => a.data.episode - b.data.episode);
---

<BaseLayout title="프리퀄" description="코드 한 줄 없이, GPT 9인과 서비스를 설계한 이야기">
  <div class="mb-8">
    <a href="/" class="text-sm text-muted hover:text-accent transition-colors">&larr; 홈</a>
  </div>

  <h1 class="text-2xl font-bold mb-2 text-gray-900">프리퀄: GPT 9인과 서비스를 설계하다</h1>
  <p class="text-muted mb-10">코드 한 줄 없이, AI 팀원 9명과 3개월간 서비스의 근간을 잡아간 이야기.</p>

  <div class="space-y-2">
    {prequels.map(p => (
      <a href={`/prequel/${p.id.replace('.md', '')}`} class="block group">
        <div class="flex items-start gap-4 py-3 border-b border-gray-100 group-hover:border-accent transition-colors">
          <span class="text-sm text-muted w-16 shrink-0 pt-0.5">
            {p.data.episode === 0 ? '프롤로그' : `${p.data.episode}화`}
          </span>
          <div>
            <span class="text-gray-800 group-hover:text-accent transition-colors font-medium">
              {p.data.title.replace(/^\d+화:\s*/, '').replace(/^프롤로그:\s*/, '')}
            </span>
            <p class="text-sm text-muted mt-1">{p.data.description}</p>
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
