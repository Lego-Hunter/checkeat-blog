---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const techs = (await getCollection('tech')).sort((a, b) => a.data.order - b.data.order);

// Phase별 그룹핑
const phases = new Map<number, { name: string; articles: typeof techs }>();
for (const t of techs) {
  if (!phases.has(t.data.phase)) {
    phases.set(t.data.phase, { name: t.data.phaseName, articles: [] });
  }
  phases.get(t.data.phase)!.articles.push(t);
}
---

<BaseLayout title="기술 블로그" description="첵잇 개발 기술 블로그 — 공공데이터 레시피 + AI 협업 이야기 25편">
  <div class="mb-8">
    <a href="/" class="text-sm text-muted hover:text-accent transition-colors">&larr; 홈</a>
  </div>

  <h1 class="text-2xl font-bold mb-2 text-gray-900">기술 블로그</h1>
  <p class="text-muted mb-10">갈림길 → 선택 → 구현 → 결과. "어떻게, 왜 이렇게"를 다룹니다.</p>

  {[...phases.entries()].map(([phaseNum, { name, articles }]) => (
    <section class="mb-12">
      <h2 class="text-lg font-bold text-gray-900 mb-1">
        Phase {phaseNum}: {name}
      </h2>
      <div class="space-y-2 mt-4">
        {articles.map(t => (
          <a href={`/tech/${t.id.replace('.md', '')}`} class="block group">
            <div class="flex items-start gap-4 py-3 border-b border-gray-100 group-hover:border-accent transition-colors">
              <span class={`text-xs px-2 py-0.5 rounded shrink-0 mt-0.5 ${
                t.data.series === 'public-data'
                  ? 'bg-blue-50 text-blue-600'
                  : 'bg-purple-50 text-purple-600'
              }`}>
                {t.data.series === 'public-data' ? '공공데이터' : 'AI 협업'}
              </span>
              <div>
                <span class="text-gray-800 group-hover:text-accent transition-colors font-medium">
                  {t.data.title}
                </span>
                <p class="text-sm text-muted mt-1">대응: {t.data.storyRef}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
