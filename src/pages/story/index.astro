---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('story')).sort((a, b) => a.data.episode - b.data.episode);
---

<BaseLayout title="운영 블로그" description="비개발자도 읽을 수 있는 첵잇 개발 이야기 22편">
  <div class="mb-8">
    <a href="/" class="text-sm text-muted hover:text-accent transition-colors">&larr; 홈</a>
  </div>

  <h1 class="text-2xl font-bold mb-2 text-gray-900">운영 블로그</h1>
  <p class="text-muted mb-10">비개발자도 읽을 수 있는 연재물. 의사결정, 시행착오, 실패와 발견의 기록.</p>

  <div class="space-y-2">
    {stories.map(s => (
      <a href={`/story/${s.id.replace('.md', '')}`} class="block group">
        <div class="flex items-start gap-4 py-3 border-b border-gray-100 group-hover:border-accent transition-colors">
          <span class="text-sm text-muted w-16 shrink-0 pt-0.5">
            {s.data.episode === 0 ? '프롤로그' : `${s.data.episode}화`}
          </span>
          <div>
            <span class="text-gray-800 group-hover:text-accent transition-colors font-medium">
              {s.data.title.replace(/^\d+화:\s*/, '').replace(/^프롤로그:\s*/, '')}
            </span>
            <p class="text-sm text-muted mt-1">{s.data.description}</p>
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
